generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id Int @id @default(autoincrement())
  name String
  iconUrl String
  xCoord Float
  yCoord Float
  // radius Float @default(0.02) //maybe store in js instead?
  foundInGames GameFoundCharacter[]
}

model Game {
  id Int @id @default(autoincrement())
  startedAt DateTime @default(now())
  endedAt DateTime? //maybe do not make default updatedAt? only populate when all 3 characters are found instead?
  durationMs Int? //calculate in js, from start time to the time 3 updates were entered?
  playerName String?//do I remove default value and just show anonymous on frontend if db empty?
  foundCharacters GameFoundCharacter[]
  // scores Score[]
}

model GameFoundCharacter {
  foundAt DateTime @default(now())
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade) 
  gameId Int

  character Character @relation(fields: [characterId], references: [id])
  characterId Int

  @@id([gameId, characterId])
}
